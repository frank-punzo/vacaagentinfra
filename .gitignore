# Terraform state — never commit
terraform.tfstate
terraform.tfstate.backup
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl

# Secrets — never commit
*.tfvars
*.tfvars.json
!*.tfvars.example

# Local overrides
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Crash logs
crash.log
crash.*.log

# Terraform RC
.terraformrc
terraform.rc

# Lambda / build artifacts
*.zip
*.pyc
__pycache__/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Local env files
.env
.env.*
!.env.example

# Lambda deployment packages
lambda_function/
lambda_layer/
placeholder/
